# ==========================================
# EMPOWERRURAL - WORKSPACE ENVIRONMENT TEMPLATE
# Copy to .env in root or set respective variables inside apps/web and apps/api
# ==========================================

# Backend API Configuration
PORT=5000
NODE_ENV=development
API_URL=http://localhost:5000

# Supabase Configuration
# If these are left blank or unset, the app runs in full offline mock/fallback mode
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI Integration
# Leave empty to use local rule-based AI Coach/Resume Analyst/Interview Coach
GEMINI_API_KEY=
